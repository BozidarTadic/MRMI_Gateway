@page "/discovery"
@using MRMI.Gateway.Client
@inject DemoState State

<PageTitle>User Discovery</PageTitle>

<div class="discovery-layout">
    <h5 class="mb-1">User Discovery</h5>
    <p class="text-muted small mb-3">
        Search registered users across both corridor nodes. Results include an opaque one-time
        connect token valid for 5 minutes.
    </p>

    <!-- ── Search bar ──────────────────────────────────────────────────── -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col">
                    <label class="form-label form-label-sm mb-1">Search query</label>
                    <input class="form-control form-control-sm" @bind="_query" @bind:event="oninput"
                           @onkeydown="QueryKeyDown"
                           placeholder="Display name, e.g. Marko or Иван…" />
                </div>
                <div class="col-auto">
                    <button class="btn btn-primary btn-sm" @onclick="SearchBoth" disabled="@_searching">
                        @(_searching ? "Searching…" : "Search both nodes")
                    </button>
                </div>
            </div>

            <!-- Demo shortcuts -->
            <div class="mt-2 d-flex flex-wrap gap-1 align-items-center">
                <span class="text-muted small me-1">Demo:</span>
                @foreach (var hint in _demoHints)
                {
                    <button class="btn btn-outline-secondary btn-xs" @onclick="() => QuickSearch(hint)">@hint</button>
                }
                <button class="btn btn-outline-primary btn-xs ms-1" @onclick="SearchAll">Show all users</button>
            </div>
        </div>
    </div>

    @if (_error is not null)
    {
        <div class="alert alert-warning small py-2">@_error</div>
    }

    <!-- ── Results ─────────────────────────────────────────────────────── -->
    @if (_results.Count > 0)
    {
        <div class="mb-1 small text-muted">
            Found <strong>@_results.Count</strong> user(s) for <em>"@_lastQuery"</em>
        </div>

        <div class="discovery-results">
            @foreach (var r in _results)
            {
                var regionFlag = r.SourceNode == DemoState.RsRegion ? "🇷🇸" : "🇷🇺";
                var name = string.IsNullOrEmpty(r.Result.DisplayHint) ? r.Result.UserId : r.Result.DisplayHint;
                var tokenKey = $"{r.SourceNode}:{r.Result.OpaqueToken}";
                <div class="discovery-card">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="fw-semibold">
                                @regionFlag <span>@name</span>
                                <span class="badge bg-secondary ms-1">@r.Result.Region</span>
                                <span class="badge bg-light text-dark border ms-1">found on @r.SourceNode</span>
                            </div>
                            <div class="small text-muted mt-1">
                                app: <code>@r.Result.AppId</code>
                                &nbsp;·&nbsp; user: <code>@r.Result.UserId</code>
                                &nbsp;·&nbsp; node: <code>@r.Result.NodeId</code>
                            </div>
                            @if (!string.IsNullOrEmpty(r.Result.OpaqueToken))
                            {
                                var exp = DateTimeOffset.FromUnixTimeSeconds(r.Result.TokenExpires).ToLocalTime();
                                <div class="small text-muted font-monospace mt-1">
                                    token: @r.Result.OpaqueToken[..Math.Min(24, r.Result.OpaqueToken.Length)]…
                                    &nbsp;(expires @exp.ToString("HH:mm:ss"))
                                </div>
                            }
                        </div>

                        <div class="d-flex flex-column align-items-end gap-1 ms-3">
                            <button class="btn btn-sm btn-outline-primary"
                                    @onclick="() => Connect(r)"
                                    disabled="@(_connecting == tokenKey || string.IsNullOrEmpty(r.Result.OpaqueToken))">
                                @(_connecting == tokenKey ? "Connecting…" : "Connect")
                            </button>
                            @if (_connectResults.TryGetValue(tokenKey, out var cr))
                            {
                                var cls = cr.IsAccepted ? "bg-success"
                                    : cr.Status == "PENDING" ? "bg-warning text-dark" : "bg-danger";
                                <span class="badge @cls">@cr.Status</span>
                                @if (cr.SessionId is not null)
                                {
                                    <div class="small text-muted font-monospace" style="font-size:0.68rem">
                                        session: @cr.SessionId[..Math.Min(12, cr.SessionId.Length)]…
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_searched && _error is null)
    {
        <div class="text-muted small">No users found for <em>"@_lastQuery"</em> on either node.</div>
    }

    <!-- ── How it works ────────────────────────────────────────────────── -->
    <div class="discovery-explainer mt-4">
        <strong>How it works</strong>
        <ol class="mb-0 mt-1">
            <li>This demo searches <strong>both</strong> RS and RU nodes simultaneously via <code>GET /api/v1/discover</code>.</li>
            <li>Each node returns users registered in its local <code>[apps]</code> config with a single-use opaque token (TTL 5 min).</li>
            <li>Clicking <strong>Connect</strong> posts that token to <code>POST /api/v1/connect</code> on the issuing node.</li>
            <li>The node applies its <code>auto_accept</code> policy — both demo nodes use <code>auto_all</code>, so all connects are <span class="badge bg-success">ACCEPTED</span> instantly.</li>
        </ol>
        <div class="mt-2 text-muted" style="font-size:0.8rem">
            In production, federated discovery fans out via the <code>BroadcastDiscovery</code> gRPC RPC
            with hop-limited gossip across alliance nodes.
        </div>
    </div>
</div>

@code {
    private string _query = "";
    private string _lastQuery = "";
    private bool _searching;
    private bool _searched;
    private string? _error;

    private readonly List<NodeResult> _results = [];
    private string? _connecting;
    private readonly Dictionary<string, ConnectResult> _connectResults = [];

    private readonly string[] _demoHints = ["Marko", "Иван", "Ana", "Ольга", "Stefan", "Дмитрий"];

    private sealed record NodeResult(string SourceNode, DiscoveryResult Result);

    protected override async Task OnInitializedAsync()
    {
        // Auto-load all users when page opens
        await SearchAll();
    }

    private async Task QueryKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchBoth();
    }

    private async Task QuickSearch(string hint)
    {
        _query = hint;
        await SearchBoth();
    }

    private async Task SearchAll()
    {
        _query = "";
        await RunSearch("");
    }

    private async Task SearchBoth()
    {
        await RunSearch(_query.Trim());
    }

    private async Task RunSearch(string q)
    {
        _searching = true;
        _error = null;
        _results.Clear();
        _searched = false;
        _lastQuery = string.IsNullOrEmpty(q) ? "(all)" : q;

        try
        {
            var rsTask = State.RsClient.DiscoverAsync(q);
            var ruTask = State.RuClient.DiscoverAsync(q);
            await Task.WhenAll(rsTask, ruTask);

            foreach (var r in rsTask.Result)
                _results.Add(new NodeResult(DemoState.RsRegion, r));
            foreach (var r in ruTask.Result)
                _results.Add(new NodeResult(DemoState.RuRegion, r));

            _searched = true;
        }
        catch (Exception ex)
        {
            _error = $"Discovery failed: {ex.Message}";
        }
        finally
        {
            _searching = false;
        }
    }

    private async Task Connect(NodeResult nr)
    {
        var tokenKey = $"{nr.SourceNode}:{nr.Result.OpaqueToken}";
        _connecting = tokenKey;
        try
        {
            // Connect via the same node that issued the token
            var client = nr.SourceNode == DemoState.RsRegion ? State.RsClient : State.RuClient;
            var requesterId = nr.SourceNode == DemoState.RsRegion ? "ivan-01" : "marko-01";
            var requesterRegion = nr.SourceNode == DemoState.RsRegion ? DemoState.RuRegion : DemoState.RsRegion;
            var cr = await client.ConnectAsync(nr.Result.OpaqueToken, requesterId, requesterRegion);
            _connectResults[tokenKey] = cr;
        }
        catch (Exception ex)
        {
            _connectResults[tokenKey] = new ConnectResult
            {
                Status = $"ERROR: {ex.Message[..Math.Min(60, ex.Message.Length)]}"
            };
        }
        finally
        {
            _connecting = null;
        }
    }
}
