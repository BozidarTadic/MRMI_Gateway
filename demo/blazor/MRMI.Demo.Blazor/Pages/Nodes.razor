@page "/nodes"
@inject DemoState State
@implements IDisposable

<PageTitle>Nodes</PageTitle>

<div class="nodes-layout">
    <div class="nodes-header">
        <div>
            <h5 class="mb-1">Nodes</h5>
            <div class="text-muted small">Open each node dashboard, inspect settings/logs, and run non-happy-path demo cases.</div>
        </div>
        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="LoadNodes" disabled="@_loading">
            @(_loading ? "Loading..." : "Refresh")
        </button>
    </div>

    <div class="node-grid">
        @foreach (var node in _nodes)
        {
            <div class="node-card">
                <div class="node-card-head">
                    <div>
                        <div class="node-title">@node.Label Node</div>
                        <div class="node-url">@node.BaseUrl</div>
                    </div>
                    <span class="node-pill @(node.Online ? "node-online" : "node-offline")">@(node.Online ? "online" : "offline")</span>
                </div>

                @if (node.Status is not null)
                {
                    <div class="node-facts">
                        <div><span>id</span><strong>@node.Status.NodeId</strong></div>
                        <div><span>region</span><strong>@node.Status.Region</strong></div>
                        <div><span>profile</span><strong>@node.Status.Profile</strong></div>
                        <div><span>law</span><strong>@node.Status.ApplicableLaw</strong></div>
                    </div>
                }
                else
                {
                    <div class="node-error">@node.Error</div>
                }

                <div class="node-actions">
                    <a class="btn btn-sm btn-primary" href="@($"{node.BaseUrl}/ui/")" target="_blank">Open dashboard</a>
                    <a class="btn btn-sm btn-outline-secondary" href="@($"{node.BaseUrl}/ui/")" target="_blank">Settings</a>
                    <a class="btn btn-sm btn-outline-secondary" href="@($"{node.BaseUrl}/ui/")" target="_blank">Audit / DLQ</a>
                </div>

                <div class="node-section-title">Latest audit</div>
                <div class="node-mini-log">
                    @foreach (var entry in node.Audit.Take(4))
                    {
                        <div class="node-log-row">
                            <span class="badge @(entry.Decision == "ALLOW" ? "bg-success" : entry.Decision == "DENY" ? "bg-danger" : "bg-warning text-dark")">@entry.Decision</span>
                            <span>@entry.SenderRegion -> @entry.RecipientRegion</span>
                            <span class="text-muted">@entry.Reason</span>
                        </div>
                    }
                    @if (!node.Audit.Any())
                    {
                        <div class="text-muted small">No audit entries yet.</div>
                    }
                </div>

                <div class="node-section-title">DLQ</div>
                <div class="text-muted small">@node.Dlq.Count entries</div>
            </div>
        }
    </div>

    <div class="scenario-panel">
        <div class="section-title">Policy playground</div>
        <div class="scenario-presets">
            <button type="button" class="btn btn-sm btn-outline-success" @onclick="() => ApplyPreset(DemoScenario.AllowedRsToRu)" disabled="@_scenarioRunning">
                Allowed corridor
            </button>
            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ApplyPreset(DemoScenario.DeniedBlockedJurisdiction)" disabled="@_scenarioRunning">
                Blocked jurisdiction
            </button>
            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => ApplyPreset(DemoScenario.LowTrustTier)" disabled="@_scenarioRunning">
                Low trust tier
            </button>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => ApplyPreset(DemoScenario.UnknownRegion)" disabled="@_scenarioRunning">
                Unknown region
            </button>
            <button type="button" class="btn btn-sm btn-outline-warning" @onclick="() => ApplyPreset(DemoScenario.DuplicateIdempotency)" disabled="@_scenarioRunning">
                Duplicate key
            </button>
        </div>

        <div class="scenario-form">
            <label>
                <span>Node</span>
                <select class="form-select form-select-sm" @bind="_scenarioNode">
                    <option value="RS">RS node</option>
                    <option value="RU">RU node</option>
                </select>
            </label>
            <label>
                <span>Sender</span>
                <input class="form-control form-control-sm" maxlength="8" @bind="_senderRegion" @bind:event="oninput" />
            </label>
            <label>
                <span>Recipient</span>
                <input class="form-control form-control-sm" maxlength="8" @bind="_recipientRegion" @bind:event="oninput" />
            </label>
            <label>
                <span>Trust tier</span>
                <input class="form-control form-control-sm" type="number" min="0" max="9" @bind="_trustTier" @bind:event="oninput" />
            </label>
            <label class="scenario-payload">
                <span>Payload</span>
                <input class="form-control form-control-sm" @bind="_payload" @bind:event="oninput" />
            </label>
        </div>

        <div class="scenario-runbar">
            <div class="text-muted small">@_scenarioName</div>
            <button type="button" class="btn btn-sm btn-primary" @onclick="RunCustomScenario" disabled="@_scenarioRunning">
                @(_scenarioRunning ? "Running..." : "Run scenario")
            </button>
        </div>

        @if (_scenarioResult is not null)
        {
            <div class="scenario-result-card">
                <div class="scenario-result-head">
                    <span class="badge @BadgeClass(_scenarioResult.Decision)">@_scenarioResult.Decision</span>
                    <strong>@_scenarioResult.Name</strong>
                    <span class="text-muted">@_scenarioResult.SenderRegion -> @_scenarioResult.RecipientRegion</span>
                </div>
                <div class="scenario-detail-grid">
                    <div><span>reason</span><strong>@_scenarioResult.Reason</strong></div>
                    <div><span>node</span><strong>@_scenarioResult.Node</strong></div>
                    <div><span>node id</span><strong>@TextOrDash(_scenarioResult.NodeId)</strong></div>
                    <div><span>profile</span><strong>@TextOrDash(_scenarioResult.Profile)</strong></div>
                    <div><span>trust tier</span><strong>@_scenarioResult.TrustTier</strong></div>
                    <div><span>local audit root</span><code title="@_scenarioResult.AuditRootHash">@ShortHash(_scenarioResult.AuditRootHash)</code></div>
                    <div><span>peer audit root</span><code title="@_scenarioResult.PeerAuditRootHash">@ShortHash(_scenarioResult.PeerAuditRootHash)</code></div>
                    <div><span>key</span><code title="@_scenarioResult.IdempotencyKey">@_scenarioResult.IdempotencyKey</code></div>
                    <div class="scenario-detail-wide"><span>payload</span><strong>@_scenarioResult.Payload</strong></div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private IReadOnlyList<NodeSnapshot> _nodes = [];
    private ScenarioResult? _scenarioResult;
    private bool _loading;
    private bool _scenarioRunning;
    private string _scenarioName = "";
    private string _scenarioSlug = "";
    private string _scenarioNode = "RS";
    private string _senderRegion = DemoState.RsRegion;
    private string _recipientRegion = DemoState.RuRegion;
    private int _trustTier = 1;
    private string _payload = "";

    protected override async Task OnInitializedAsync()
    {
        State.OnChanged += OnStateChanged;
        ApplyRequest(ScenarioRunRequest.BlockedJurisdiction());
        await LoadNodes();
    }

    private async Task LoadNodes()
    {
        _loading = true;
        _nodes = await State.LoadNodeSnapshotsAsync();
        _loading = false;
    }

    private async Task RunScenario(DemoScenario scenario)
    {
        ApplyPreset(scenario);
        await RunCustomScenario();
    }

    private async Task RunCustomScenario()
    {
        _scenarioRunning = true;
        var request = new ScenarioRunRequest(
            _scenarioName,
            _scenarioSlug,
            _scenarioNode,
            NormalizeRegion(_senderRegion),
            NormalizeRegion(_recipientRegion),
            _trustTier < 0 ? 0u : (uint)_trustTier,
            string.IsNullOrWhiteSpace(_payload) ? "(empty scenario payload)" : _payload);

        _scenarioResult = await State.RunScenarioAsync(request);
        _nodes = await State.LoadNodeSnapshotsAsync();
        _scenarioRunning = false;
    }

    private void ApplyPreset(DemoScenario scenario)
    {
        var request = scenario switch
        {
            DemoScenario.AllowedRsToRu => ScenarioRunRequest.AllowedCorridor(),
            DemoScenario.DeniedBlockedJurisdiction => ScenarioRunRequest.BlockedJurisdiction(),
            DemoScenario.LowTrustTier => ScenarioRunRequest.LowTrustTier(),
            DemoScenario.UnknownRegion => ScenarioRunRequest.UnknownRegion(),
            DemoScenario.DuplicateIdempotency => ScenarioRunRequest.AllowedCorridor() with
            {
                Name = "Duplicate idempotency key",
                Slug = "duplicate",
                Payload = "First and second sends reuse the same idempotency key",
            },
            _ => ScenarioRunRequest.BlockedJurisdiction(),
        };
        ApplyRequest(request);
    }

    private void ApplyRequest(ScenarioRunRequest request)
    {
        _scenarioName = request.Name;
        _scenarioSlug = request.Slug;
        _scenarioNode = request.Node;
        _senderRegion = request.SenderRegion;
        _recipientRegion = request.RecipientRegion;
        _trustTier = (int)request.TrustTier;
        _payload = request.Payload;
    }

    private static string BadgeClass(string decision) => decision switch
    {
        "ALLOW" => "bg-success",
        "DENY" => "bg-danger",
        "DUPLICATE" => "bg-warning text-dark",
        _ => "bg-secondary",
    };

    private static string NormalizeRegion(string value)
        => string.IsNullOrWhiteSpace(value) ? "ZZ" : value.Trim().ToUpperInvariant();

    private static string TextOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string ShortHash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value.Length > 12 ? value[..12] + "..." : value;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => State.OnChanged -= OnStateChanged;
}
