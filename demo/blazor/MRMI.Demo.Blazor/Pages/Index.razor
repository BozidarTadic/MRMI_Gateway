@page "/"
@using MRMI.Gateway.Client
@inject DemoState State
@implements IDisposable

<PageTitle>MRMI Gateway — Chat</PageTitle>

<div class="chat-layout">
    <div class="chat-panels">

        <!-- ── RS Panel ─────────────────────────────────────────────────── -->
        <div class="panel panel-rs">
            <div class="panel-header">
                <span>&#127480;&#127479; @DemoState.RsUser</span>
                <small class="text-muted">RS &middot; @(State.RsOnline ? "🟢 live" : "⚪ connecting…")</small>
            </div>

            <div class="chat-thread">
                @foreach (var msg in State.RsMessages)
                {
                    var sent = msg.FromRegion == DemoState.RsRegion;
                    <div class="msg-row @(sent ? "row-sent" : "row-received")">
                        <div class="msg-bubble @(sent ? "msg-sent" : "msg-received")">
                            @msg.Text
                            <div class="msg-meta">@msg.Timestamp.ToLocalTime().ToString("HH:mm:ss")</div>
                        </div>
                    </div>
                }
                @if (!State.RsMessages.Any())
                {
                    <div class="no-messages">No messages yet — type below to send one.</div>
                }
            </div>

            <div class="chat-input">
                <input class="form-control form-control-sm"
                       @bind="_rsText" @bind:event="oninput"
                       @onkeydown="RsKeyDown"
                       placeholder="Message to Ivan…" />
                <button class="btn btn-sm btn-corridor-rs" @onclick="SendRs" disabled="@_rsSending">
                    @(_rsSending ? "…" : "Send →")
                </button>
            </div>

            @if (_rsStatus is not null)
            {
                <div class="send-status @(_rsStatus.StartsWith("ALLOW") ? "status-ok" : "status-err")">
                    @_rsStatus
                </div>
            }
        </div>

        <!-- ── RU Panel ─────────────────────────────────────────────────── -->
        <div class="panel panel-ru">
            <div class="panel-header">
                <span>&#127479;&#127482; @DemoState.RuUser</span>
                <small class="text-muted">RU &middot; @(State.RuOnline ? "🟢 live" : "⚪ connecting…")</small>
            </div>

            <div class="chat-thread">
                @foreach (var msg in State.RuMessages)
                {
                    var sent = msg.FromRegion == DemoState.RuRegion;
                    <div class="msg-row @(sent ? "row-sent" : "row-received")">
                        <div class="msg-bubble @(sent ? "msg-sent" : "msg-received")">
                            @msg.Text
                            <div class="msg-meta">@msg.Timestamp.ToLocalTime().ToString("HH:mm:ss")</div>
                        </div>
                    </div>
                }
                @if (!State.RuMessages.Any())
                {
                    <div class="no-messages">No messages yet — type below to send one.</div>
                }
            </div>

            <div class="chat-input">
                <button class="btn btn-sm btn-corridor-ru" @onclick="SendRu" disabled="@_ruSending">
                    @(_ruSending ? "…" : "← Send")
                </button>
                <input class="form-control form-control-sm"
                       @bind="_ruText" @bind:event="oninput"
                       @onkeydown="RuKeyDown"
                       placeholder="Message to Marko…" />
            </div>

            @if (_ruStatus is not null)
            {
                <div class="send-status @(_ruStatus.StartsWith("ALLOW") ? "status-ok" : "status-err")">
                    @_ruStatus
                </div>
            }
        </div>
    </div>

    <div class="chat-actions">
        <button class="btn btn-sm btn-outline-secondary" @onclick="State.ClearMessages">Clear messages</button>
        <span class="text-muted small ms-2">
            Messages arrive via SSE stream · both sides can send and reply
        </span>
    </div>
</div>

@code {
    private string _rsText = "Hello from Serbia!";
    private string _ruText = "Привет из России!";
    private bool _rsSending, _ruSending;
    private string? _rsStatus, _ruStatus;

    protected override void OnInitialized()
    {
        State.OnChanged += OnStateChanged;
        State.StartStreaming();
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private async Task RsKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendRs();
    }

    private async Task RuKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendRu();
    }

    private async Task SendRs()
    {
        if (string.IsNullOrWhiteSpace(_rsText)) return;
        _rsSending = true;
        _rsStatus = null;
        var text = _rsText;
        _rsText = "";
        var (decision, reason) = await State.SendAsync(DemoState.RsRegion, DemoState.RuRegion, text);
        _rsStatus = $"{decision} — {reason}";
        _rsSending = false;
    }

    private async Task SendRu()
    {
        if (string.IsNullOrWhiteSpace(_ruText)) return;
        _ruSending = true;
        _ruStatus = null;
        var text = _ruText;
        _ruText = "";
        var (decision, reason) = await State.SendAsync(DemoState.RuRegion, DemoState.RsRegion, text);
        _ruStatus = $"{decision} — {reason}";
        _ruSending = false;
    }

    public void Dispose() => State.OnChanged -= OnStateChanged;
}
